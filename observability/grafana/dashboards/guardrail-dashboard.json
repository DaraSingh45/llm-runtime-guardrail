{
  "title": "LLM Runtime Guardrail",
  "uid": "llm-guardrail-overview",
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Requests (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "rate(guardrail_requests_total[1m]) * 60", "legendFormat": "requests/min" }]
    },
    {
      "id": 2,
      "title": "Blocked Requests by Direction",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum by (direction) (rate(guardrail_requests_blocked_total[1m])) * 60", "legendFormat": "{{direction}}" }
      ]
    },
    {
      "id": 3,
      "title": "Findings by Layer",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum by (layer) (rate(guardrail_findings_total[1m])) * 60", "legendFormat": "{{layer}}" }
      ]
    },
    {
      "id": 4,
      "title": "Block Rate (%)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(rate(guardrail_requests_blocked_total[5m])) / sum(rate(guardrail_requests_total[5m])) * 100" }
      ]
    },
    {
      "id": 5,
      "title": "Scan Latency (p95, seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(guardrail_scan_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 scan latency"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
